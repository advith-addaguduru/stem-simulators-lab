# ─── STEM Lab Environment Configuration ──────────────────────────────────────
# Copy to .env and adjust values for your deployment.
# All settings have sensible defaults — only override what you need.

# Database path (default: data/stemlab.db)
# STEMLAB_DATABASE_URL=data/stemlab.db

# Secret key for session signing — CHANGE THIS IN PRODUCTION
STEMLAB_SECRET_KEY=change-me-to-a-long-random-string

# bcrypt hashing rounds (default: 12, higher = slower but more secure)
# STEMLAB_BCRYPT_ROUNDS=12

# Session idle timeout in seconds (default: 1800 = 30 minutes)
# STEMLAB_SESSION_TIMEOUT=1800

# Max failed login attempts before account lockout (default: 5)
# STEMLAB_MAX_LOGIN_ATTEMPTS=5

# Account lock duration in seconds after max failures (default: 900 = 15 min)
# STEMLAB_LOGIN_LOCK_SECONDS=900

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
# STEMLAB_LOG_LEVEL=INFO

# Support email displayed on legal pages
# STEMLAB_SUPPORT_EMAIL=advith.addaguduru@gmail.com

# ─── Guardrails ───────────────────────────────────────────────────────────────
# Rate-limit sliding window in seconds (default: 60)
# STEMLAB_RATE_LIMIT_WINDOW=60

# Max login attempts per identifier per window (default: 10)
# STEMLAB_RATE_LIMIT_MAX_LOGIN=10

# Max signups per window (default: 5)
# STEMLAB_RATE_LIMIT_MAX_SIGNUP=5

# Max concurrent sessions per user (default: 3)
# STEMLAB_MAX_SESSIONS=3

# Password complexity flags (1 = required, 0 = off)
# STEMLAB_PW_REQUIRE_UPPER=1
# STEMLAB_PW_REQUIRE_LOWER=1
# STEMLAB_PW_REQUIRE_DIGIT=1
# STEMLAB_PW_REQUIRE_SPECIAL=0
